#!/bin/bash
#
# Installation:
# sudo curl -fsSL https://raw.githubusercontent.com/deforay/utility-scripts/master/php/switch-php -o /usr/local/bin/switch-php && sudo chmod +x /usr/local/bin/switch-php
#
# Usage:
# sudo switch-php 8.2
# sudo switch-php 8.3 --force
# sudo switch-php 8.4 --fpm     # also install php-fpm (opt-in; never pulled in implicitly)
#
# Robust PHP Switcher for Ubuntu
# Idempotent, Resilient, and Safe
#
set -euo pipefail
IFS=$'\n\t'

# --- Configuration ---
LOG_FILE="/var/log/php-switch.log"
LOCK_FILE="/var/lock/php-switch.lock"
RETRIES=3
DELAY=5

# Prevent apt from prompting for user input (needrestart dialogs, etc.)
export DEBIAN_FRONTEND=noninteractive
export NEEDRESTART_MODE=a

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# --- Helper Functions ---

log() {
    local level="$1"
    local msg="$2"
    local timestamp
    timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo -e "${timestamp} [${level}] ${msg}" | tee -a "$LOG_FILE"
}

info() { log "INFO" "${GREEN}${1}${NC}"; }
warn() { log "WARN" "${YELLOW}${1}${NC}"; }
error() { log "ERROR" "${RED}${1}${NC}"; }
fatal() { log "FATAL" "${RED}${1}${NC}"; exit 1; }

# Check if Apache is actually installed (not just leftover config dirs)
is_apache_installed() {
    command -v apache2 >/dev/null 2>&1 || command -v apachectl >/dev/null 2>&1
}

# Check whether apt currently knows about a package.
# This lets us fail with a clear mod_php-specific message instead of a generic apt error.
is_package_available() {
    local package_name="$1"
    apt-cache show "$package_name" >/dev/null 2>&1
}

get_ubuntu_release() {
    if [[ -r /etc/os-release ]]; then
        . /etc/os-release
        echo "${VERSION_ID:-unknown}"
    else
        echo "unknown"
    fi
}

fatal_mod_php_unavailable() {
    local version="$1"
    local package_name="libapache2-mod-php${version}"
    local ubuntu_release
    ubuntu_release=$(get_ubuntu_release)

    fatal "Apache is installed and this script uses mod_php, but package ${package_name} is not available from apt on Ubuntu ${ubuntu_release}. PHP ${version} cannot be activated with mod_php on this host using the current repositories. Upgrade Ubuntu or provide a repository/build that includes ${package_name}."
}

# Retry wrapper for network/lock sensitive commands
run_with_retry() {
    local n=1
    local max=$RETRIES
    local delay=$DELAY
    while true; do
        if "$@"; then
            return 0
        else
            if [[ $n -lt $max ]]; then
                ((n++))
                warn "Command failed. Retrying $n/$max in ${delay}s..."
                sleep $delay
            else
                error "The command has failed after $n attempts."
                return 1
            fi
        fi
    done
}

# --- Pre-flight Checks ---

if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    fatal "Please run as root."
fi

# Acquire lock to prevent concurrent runs
exec 200>"$LOCK_FILE"
flock -n 200 || fatal "Another instance is already running."

# --- Argument Parsing ---

if [[ $# -lt 1 ]]; then
    echo "Usage: $0 <php-version> [options]"
    echo "Options: --force | --no-update | --fast | --fpm"
    echo "Example: $0 8.2 --force"
    exit 1
fi

PHP_VERSION="$1"
shift

FORCE_MODE=false
SKIP_UPDATE=false
FAST_MODE=false
WANT_FPM=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -f|--force) FORCE_MODE=true ;;
        --no-update) SKIP_UPDATE=true ;;
        --fast)
            FAST_MODE=true
            SKIP_UPDATE=true
            ;;
        --fpm) WANT_FPM=true ;;
        *) warn "Unknown option: $1" ;;
    esac
    shift
done

if [[ "$FAST_MODE" == "true" ]]; then
    info "Fast mode enabled: skipping apt update and optional extensions."
fi

info "Starting PHP Switch to version: $PHP_VERSION"

# --- System Prep ---

# Ensure basic tools are present (idempotent)
ensure_base_tools() {
    info "Ensuring base tools..."
    # Check if we need to install anything to avoid apt overhead
    if ! dpkg -s software-properties-common curl unzip >/dev/null 2>&1; then
        run_with_retry apt-get update
        run_with_retry apt-get install -y software-properties-common curl unzip acl
    fi
}

# HEAD-probe a Launchpad PPA Release URL for the given codename. Returns 0
# if published, 1 otherwise. curl noise is suppressed (-f alone leaks to stderr).
ppa_has_codename() {
    local ppa_path="$1" cn="$2"
    curl -fsSLI -o /dev/null --max-time 10 \
        "https://ppa.launchpadcontent.net/${ppa_path}/ubuntu/dists/${cn}/Release" 2>/dev/null
}

# Derive "ondrej/<pkg>" from a sources filename of the form
# /etc/apt/sources.list.d/ondrej-ubuntu-<pkg>-<codename>.{list,sources}
ondrej_ppa_path_from_file() {
    local file="$1" codename="$2" base ppa_path
    base=$(basename "$file")
    ppa_path="ondrej/${base#ondrej-ubuntu-}"
    ppa_path="${ppa_path%-${codename}.list}"
    ppa_path="${ppa_path%-${codename}.sources}"
    printf '%s\n' "$ppa_path"
}

# Restore the codename written *inside* an ondrej source file (it may have been
# rewritten by a previous version of this script). Operates by filename suffix.
restore_ondrej_source_codename() {
    local file="$1" codename="$2"
    case "$file" in
        *.sources) sed -i -E "s/^(Suites:[[:space:]]*).*/\1${codename}/" "$file" 2>/dev/null || true ;;
        *.list)    sed -i -E "s|(ubuntu[[:space:]]+)[a-zA-Z]+([[:space:]]+main)|\1${codename}\2|" "$file" 2>/dev/null || true ;;
    esac
}

# Add ondrej/php PPA if it publishes the current codename. If not, do nothing —
# install_php_packages will fall back to Ubuntu's stock PHP. Respect a prior
# .disabled marker so we don't re-add a PPA the user opted out of.
setup_ppa() {
    local ppa_name="ondrej/php"
    local codename
    codename=$(lsb_release -cs)
    local ppa_list="/etc/apt/sources.list.d/ondrej-ubuntu-php-${codename}.list"
    local ppa_sources="/etc/apt/sources.list.d/ondrej-ubuntu-php-${codename}.sources"

    if [[ -f "${ppa_list}.disabled" || -f "${ppa_sources}.disabled" ]]; then
        info "${ppa_name} previously disabled on '${codename}'; using distro PHP packages."
        return 0
    fi

    if [[ -f "$ppa_list" || -f "$ppa_sources" ]]; then
        info "PPA $ppa_name already present."
        return 0
    fi

    if ! ppa_has_codename "$ppa_name" "$codename"; then
        warn "${ppa_name} has no build for '${codename}'; skipping PPA, using distro PHP packages."
        return 0
    fi

    info "Adding PPA: $ppa_name"
    run_with_retry add-apt-repository -y ppa:$ppa_name
    SKIP_UPDATE=false
}

# Disable any ondrej-ubuntu-*-<codename>.{list,sources} whose codename isn't
# published by Launchpad. Cross-codename installs break due to ABI mismatches
# (e.g. the libxml2 time_t-64 transition), so we don't try to pin to a prior
# Ubuntu — we step out of the way and let apt use the distro archive.
# Covers ondrej/php (added here) and ondrej/apache2 (added by lamp-setup.sh).
disable_unsupported_ondrej_ppas() {
    local codename
    codename=$(lsb_release -cs)
    shopt -s nullglob
    local files=(/etc/apt/sources.list.d/ondrej-ubuntu-*-"${codename}".list \
                 /etc/apt/sources.list.d/ondrej-ubuntu-*-"${codename}".sources)
    shopt -u nullglob
    [[ ${#files[@]} -eq 0 ]] && return 0

    declare -A checked=()
    local file ppa_path
    for file in "${files[@]}"; do
        ppa_path=$(ondrej_ppa_path_from_file "$file" "$codename")

        if [[ -z "${checked[$ppa_path]:-}" ]]; then
            if ppa_has_codename "$ppa_path" "$codename"; then
                checked[$ppa_path]="ok"
            else
                checked[$ppa_path]="bad"
            fi
        fi

        if [[ "${checked[$ppa_path]}" == "ok" ]]; then
            # Heal a previous noble-pin so the file matches its own filename.
            restore_ondrej_source_codename "$file" "$codename"
            continue
        fi

        warn "${ppa_path} has no build for '${codename}'; disabling PPA, falling back to distro packages."
        restore_ondrej_source_codename "$file" "$codename"
        mv "$file" "${file}.disabled"
        SKIP_UPDATE=false
    done
}

# Fix any broken/half-configured packages before we start installing
fix_broken_packages() {
    if dpkg --audit 2>/dev/null | grep -q .; then
        warn "Broken packages detected. Attempting to fix..."
        # Stop any failed php-fpm services that block dpkg configure
        for fpm_service in /lib/systemd/system/php*-fpm.service; do
            [[ -f "$fpm_service" ]] || continue
            local svc
            svc=$(basename "$fpm_service")
            if systemctl is-failed "$svc" >/dev/null 2>&1; then
                warn "Resetting failed service: $svc"
                systemctl reset-failed "$svc" 2>/dev/null || true
                systemctl stop "$svc" 2>/dev/null || true
            fi
        done
        dpkg --configure -a 2>/dev/null || true
        apt-get install -f -y 2>/dev/null || true
    fi
}

fix_broken_packages
ensure_base_tools
setup_ppa
disable_unsupported_ondrej_ppas

if [[ "$SKIP_UPDATE" == "false" ]]; then
    info "Updating package lists..."
    run_with_retry apt-get update
fi

# --- PHP Installation ---

install_php_packages() {
    local version="$1"
    local apache_module_package="libapache2-mod-php${version}"
    
    # Critical packages - must succeed.
    # NOTE: we deliberately do NOT install the "php${version}" metapackage. It
    # Depends on "libapache2-mod-php | php-cgi | php-fpm | php-litespeed", and
    # apt may satisfy that "or" by pulling in php-fpm — an unrequested SAPI that
    # then fails to configure on mod_php hosts and jams the whole apt run. We
    # install exactly what's needed: cli + common here, mod_php below when
    # Apache is present, the extension set later, and FPM only via --fpm.
    local critical_packages=(
        "php${version}-cli"
        "php${version}-common"
    )

    # Make the "no such PHP version available" case loud and specific instead of
    # letting apt error out generically. Happens on brand-new Ubuntu releases
    # that Ondrej hasn't published yet AND that don't ship php${version} in the
    # main archive.
    if ! is_package_available "php${version}"; then
        local codename
        codename=$(lsb_release -cs)
        local distro_versions
        distro_versions=$(apt-cache search --names-only '^php[0-9]+\.[0-9]+$' 2>/dev/null | awk '{print $1}' | sort -u | tr '\n' ' ')
        fatal "PHP ${version} is not available in apt on this host. Ondrej PPA has no build for Ubuntu '${codename}' and the distro archive doesn't ship php${version}. Available distro PHP packages: ${distro_versions:-none}. Wait for Ondrej to publish, or pick a version Ubuntu provides."
    fi

    if is_apache_installed; then
        # Apache installations require the matching mod_php package; make the failure explicit
        # before apt-get emits a generic "Unable to locate package" message.
        if ! is_package_available "$apache_module_package"; then
            fatal_mod_php_unavailable "$version"
        fi
        critical_packages+=("$apache_module_package")
    fi

    # FPM is opt-in only (--fpm). It is never pulled in implicitly.
    if [[ "$WANT_FPM" == "true" ]]; then
        if is_package_available "php${version}-fpm"; then
            info "Including php${version}-fpm (requested via --fpm)."
            critical_packages+=("php${version}-fpm")
        else
            warn "php${version}-fpm requested but not available in apt; skipping."
        fi
    fi

    # Standard Extensions - usually required
    local standard_extensions=(
        "php${version}-curl"
        "php${version}-gd"
        "php${version}-mbstring"
        "php${version}-xml"
        "php${version}-zip"
        "php${version}-mysql"
        "php${version}-bcmath"
        "php${version}-intl"
        "php${version}-gmp"
        "php${version}-opcache"
        "php${version}-sqlite3"
        "php${version}-imagick"
    )

    # Optional Extensions - skipped in fast mode
    local optional_extensions=(
        "php${version}-redis"
        "php${version}-apcu"
        "php${version}-memcached"
    )

    info "Installing PHP $version critical packages..."
    if ! run_with_retry apt-get install -y "${critical_packages[@]}"; then
        fatal "Failed to install critical PHP packages. Aborting."
    fi

    local extensions_to_install=("${standard_extensions[@]}")
    if [[ "$FAST_MODE" == "false" ]]; then
        extensions_to_install+=("${optional_extensions[@]}")
    else
        info "Skipping optional extensions (redis, apcu, memcached)..."
    fi

    info "Installing PHP extensions..."
    # Try batch install first for speed
    if ! apt-get install -y "${extensions_to_install[@]}"; then
        warn "Batch extension install failed. Attempting individual installation..."
        for pkg in "${extensions_to_install[@]}"; do
            # Check if package exists first to avoid apt error noise
            if apt-cache show "$pkg" >/dev/null 2>&1; then
                if ! run_with_retry apt-get install -y "$pkg"; then
                    error "Failed to install $pkg"
                else
                    info "Installed $pkg"
                fi
            else
                warn "Package $pkg not found, skipping."
            fi
        done
    else
        info "All extensions installed successfully."
    fi
}

install_php_packages "$PHP_VERSION"

# --- Ensure phar is usable (Composer depends on it) ---

# phar is compiled into php-cli, but hardening profiles (CIS, custom conf.d)
# sometimes blacklist it via disable_classes/disable_functions. When they do,
# Composer aborts with "PHP's phar extension is missing" and every downstream
# installer (LIS setup/upgrade) dies. Since switch-php owns PHP for all of
# them, heal it here so `switch-php <ver>` alone is a sufficient fix.
ensure_phar_extension() {
    local version="$1"
    local php_bin="/usr/bin/php${version}"
    local cli_dir="/etc/php/${version}/cli"

    [[ -x "$php_bin" ]] || return 0

    # Already loaded? Nothing to do.
    if "$php_bin" -r 'exit(extension_loaded("phar") ? 0 : 1);' >/dev/null 2>&1; then
        info "phar extension active in PHP ${version} CLI."
        return 0
    fi

    warn "phar not active in PHP ${version} CLI; checking for a blacklist..."

    # The CLI SAPI reads php.ini plus everything symlinked into conf.d/.
    shopt -s nullglob
    local files=("${cli_dir}/php.ini" "${cli_dir}/conf.d/"*.ini)
    shopt -u nullglob

    local ts file target
    ts=$(date '+%Y%m%d%H%M%S')
    # grep over explicitly listed files reads through symlinks; guard the
    # no-match exit so set -e doesn't abort us.
    while IFS= read -r file; do
        [[ -n "$file" ]] || continue
        target=$(readlink -f "$file" 2>/dev/null || echo "$file")
        cp "$target" "${target}.bak.${ts}" 2>/dev/null || true
        sed -i -E '/^[[:space:]]*disable_(classes|functions)[[:space:]]*=.*[Pp]har/ s/^/;/' "$target"
        info "Neutralised phar blacklist in: ${target} (backup: ${target}.bak.${ts})"
    done < <(grep -lE 'disable_(classes|functions)[[:space:]]*=.*[Pp]har' "${files[@]}" 2>/dev/null || true)

    if "$php_bin" -r 'exit(extension_loaded("phar") ? 0 : 1);' >/dev/null 2>&1; then
        info "phar extension is now active."
        return 0
    fi

    # Not a blacklist — the build itself is missing phar. It lives in php-cli/
    # php-common, so a reinstall restores it.
    warn "phar still missing after blacklist check; reinstalling php${version}-cli/common..."
    run_with_retry apt-get install --reinstall -y "php${version}-cli" "php${version}-common" || true

    if "$php_bin" -r 'exit(extension_loaded("phar") ? 0 : 1);' >/dev/null 2>&1; then
        info "phar extension is now active."
        return 0
    fi

    # phar is the one extension Composer cannot run without — fail loudly rather
    # than let every downstream installer die with a cryptic Composer error.
    error "phar extension could NOT be enabled for PHP ${version}."
    error "Composer (and LIS setup/upgrade) cannot run without it."
    error "Inspect manually: ${php_bin} --ini  and  ${php_bin} -i | grep -Ei 'disable_(functions|classes)|suhosin'"
    fatal "Unable to provide a working phar extension. Aborting."
}

ensure_phar_extension "$PHP_VERSION"

# --- Verify & install any missing extensions ---

# After install_php_packages, confirm each extension is actually *loaded* in the
# CLI (a package can be installed but its module disabled/blacklisted). For any
# that's missing, (re)install the owning package and re-check. Non-fatal: warn
# and move on so a single odd extension doesn't block the whole switch. phar is
# handled separately above because it's mandatory.
verify_and_install_extensions() {
    local version="$1"
    local php_bin="/usr/bin/php${version}"

    [[ -x "$php_bin" ]] || return 0

    # ext-name : apt package suffix (php${version}-<suffix>)
    local pairs=(
        "curl:curl"
        "gd:gd"
        "mbstring:mbstring"
        "xml:xml"
        "zip:zip"
        "mysqli:mysql"
        "pdo_mysql:mysql"
        "bcmath:bcmath"
        "intl:intl"
        "gmp:gmp"
        "Zend OPcache:opcache"
        "sqlite3:sqlite3"
        "imagick:imagick"
    )

    info "Verifying required PHP extensions are loaded..."

    local entry ext pkg still_missing=()
    for entry in "${pairs[@]}"; do
        ext="${entry%%:*}"
        pkg="${entry##*:}"
        if "$php_bin" -r "exit(extension_loaded('${ext}') ? 0 : 1);" >/dev/null 2>&1; then
            continue
        fi
        warn "Extension '${ext}' not loaded; installing php${version}-${pkg}..."
        # Skip packages apt doesn't know about (e.g. imagick on some releases).
        if ! apt-cache show "php${version}-${pkg}" >/dev/null 2>&1; then
            warn "Package php${version}-${pkg} not available in apt; skipping '${ext}'."
            continue
        fi
        run_with_retry apt-get install -y "php${version}-${pkg}" || \
            run_with_retry apt-get install --reinstall -y "php${version}-${pkg}" || true
        phpenmod -v "$version" "$pkg" 2>/dev/null || true
        if ! "$php_bin" -r "exit(extension_loaded('${ext}') ? 0 : 1);" >/dev/null 2>&1; then
            still_missing+=("${ext}")
        else
            info "Extension '${ext}' is now loaded."
        fi
    done

    if [[ ${#still_missing[@]} -gt 0 ]]; then
        warn "Still missing after install attempts: ${still_missing[*]}"
        warn "These may be unavailable for PHP ${version} on this Ubuntu release, or blacklisted."
    else
        info "All required PHP extensions are loaded."
    fi
}

verify_and_install_extensions "$PHP_VERSION"

# --- Configuration (The Idempotent Way) ---

configure_php_tuning() {
    local version="$1"
    local conf_dir="/etc/php/${version}/mods-available"
    local conf_file="${conf_dir}/99-custom-tuning.ini"

    info "Applying PHP configuration tuning..."

    # Create the directory if it doesn't exist (rare)
    mkdir -p "$conf_dir"

    # Write configuration to a separate file.
    # This is idempotent: it overwrites the file with the desired state.
    cat > "$conf_file" <<EOF
; Custom PHP Tuning generated by switch-php
; Do not edit manually, changes will be overwritten.
[PHP]
memory_limit = 512M
upload_max_filesize = 100M
post_max_size = 100M
max_execution_time = 300
date.timezone = UTC
expose_php = Off
error_reporting = E_ALL & ~E_DEPRECATED & ~E_STRICT
display_errors = Off
log_errors = On

[opcache]
opcache.enable=1
opcache.memory_consumption=128
opcache.interned_strings_buffer=8
opcache.max_accelerated_files=4000
opcache.revalidate_freq=60
EOF

    # Enable the module for all SAPIs (cli, apache2, fpm)
    # phpenmod is idempotent
    phpenmod -v "$version" 99-custom-tuning
}

configure_php_tuning "$PHP_VERSION"

# --- Apache Switching ---

switch_apache_module() {
    local version="$1"

    if ! is_apache_installed; then
        warn "Apache2 not installed, skipping module switch."
        return
    fi

    info "Switching Apache to PHP $version..."

    # Enable mpm_prefork FIRST (required for mod_php)
    # mod_php .load files won't be created if mpm_event/mpm_worker is active
    if ! a2query -m mpm_prefork >/dev/null 2>&1; then
        info "Enabling mpm_prefork (required for mod_php)..."
        # Install mpm_prefork if the module file doesn't exist
        if [[ ! -f /etc/apache2/mods-available/mpm_prefork.load ]]; then
            info "mpm_prefork module not found, installing apache2 package..."
            run_with_retry apt-get install -y apache2
        fi
        a2dismod -f mpm_event 2>/dev/null || true
        a2dismod -f mpm_worker 2>/dev/null || true
        if ! a2enmod mpm_prefork; then
            fatal "Failed to enable mpm_prefork. mod_php requires the prefork MPM."
        fi
    fi

    # Disable all other PHP modules
    # We find them dynamically to be robust against any installed version
    local current_modules
    current_modules=$(a2query -m 2>/dev/null | grep -oE 'php[0-9]+(\.[0-9]+)?' || true)

    for mod in $current_modules; do
        if [[ "$mod" != "php${version}" ]]; then
            info "Disabling Apache module: $mod"
            a2dismod -f "$mod" 2>/dev/null || true
        fi
    done

    # Verify module files exist before attempting to enable
    local mod_load="/etc/apache2/mods-available/php${version}.load"
    local mod_conf="/etc/apache2/mods-available/php${version}.conf"

    if [[ ! -f "$mod_load" ]]; then
        warn "Apache PHP module file not found: $mod_load"
        if ! is_package_available "libapache2-mod-php${version}"; then
            fatal_mod_php_unavailable "$version"
        fi
        warn "Attempting to reinstall libapache2-mod-php${version}..."

        # Force reinstall the Apache module (mpm_prefork is already active so .load will be created)
        if ! run_with_retry apt-get install --reinstall -y "libapache2-mod-php${version}"; then
            fatal "Failed to install Apache PHP module libapache2-mod-php${version} even though apt reports it as available. Check apt policy, package pinning, and repository health."
        fi

        # Re-check after reinstall
        if [[ ! -f "$mod_load" ]]; then
            fatal "Apache PHP module file still missing after reinstall: $mod_load. Manual intervention required."
        fi
        info "Apache PHP module reinstalled successfully."
    fi

    # Enable the target version
    info "Enabling Apache module: php${version}"
    if ! a2enmod "php${version}"; then
        fatal "Failed to enable php${version} Apache module."
    fi

    # Verify module is actually enabled
    if ! a2query -m "php${version}" >/dev/null 2>&1; then
        fatal "php${version} module appears enabled but a2query reports it as inactive."
    fi

    info "Apache PHP module php${version} enabled and verified."
}

switch_apache_module "$PHP_VERSION"

# --- PHP Handler Verification ---

verify_php_handler() {
    local version="$1"

    if ! is_apache_installed; then
        return
    fi

    info "Verifying PHP handler configuration..."

    local handler_conf="/etc/apache2/mods-enabled/php${version}.conf"

    # Check if the handler config symlink exists
    if [[ ! -f "$handler_conf" ]]; then
        warn "PHP handler config not linked in mods-enabled."

        # Check if source exists and try to enable
        if [[ -f "/etc/apache2/mods-available/php${version}.conf" ]]; then
            info "Enabling PHP handler configuration..."
            a2enmod "php${version}" 2>/dev/null || true
        fi
    fi

    # Verify handler directive exists in enabled configs
    local handler_found=false
    if grep -Rq 'SetHandler[[:space:]]\+application/x-httpd-php' /etc/apache2/mods-enabled/ 2>/dev/null; then
        handler_found=true
    elif [[ -f "/etc/apache2/conf-enabled/php${version}-handler.conf" ]]; then
        handler_found=true
    elif [[ -f "/etc/apache2/conf-available/php${version}-handler.conf" ]]; then
        handler_found=true
    fi

    if [[ "$handler_found" == "false" ]]; then
        warn "PHP handler directive not found. Creating fallback handler config..."

        cat > "/etc/apache2/conf-available/php${version}-handler.conf" <<'HANDLER_EOF'
# Fallback PHP handler created by switch-php
<FilesMatch "\.php$">
    SetHandler application/x-httpd-php
</FilesMatch>
<FilesMatch "\.phps$">
    SetHandler application/x-httpd-php-source
</FilesMatch>
HANDLER_EOF

        if a2enconf "php${version}-handler" 2>/dev/null; then
            info "Fallback PHP handler enabled."
        else
            error "Failed to enable fallback PHP handler."
        fi
    else
        info "PHP handler configuration verified."
    fi
}

verify_php_handler "$PHP_VERSION"

# --- CLI Alternatives ---

update_alternatives() {
    local version="$1"
    info "Updating CLI alternatives..."

    if [[ -f "/usr/bin/php${version}" ]]; then
        # Register the alternative first if not already registered (--install is idempotent)
        # Priority 100 is arbitrary; --set overrides priority-based selection anyway
        update-alternatives --install /usr/bin/php php "/usr/bin/php${version}" 100
        update-alternatives --set php "/usr/bin/php${version}"

        if [[ -f "/usr/bin/phar${version}" ]]; then
            update-alternatives --install /usr/bin/phar phar "/usr/bin/phar${version}" 100
            update-alternatives --set phar "/usr/bin/phar${version}"
        fi
        if [[ -f "/usr/bin/phar.phar${version}" ]]; then
            update-alternatives --install /usr/bin/phar.phar phar.phar "/usr/bin/phar.phar${version}" 100
            update-alternatives --set phar.phar "/usr/bin/phar.phar${version}"
        fi
    else
        error "Binary /usr/bin/php${version} not found!"
    fi
}

update_alternatives "$PHP_VERSION"

# --- Composer ---

install_composer() {
    if command -v composer >/dev/null 2>&1 && [[ "$FORCE_MODE" == "false" ]]; then
        info "Composer already installed."
        return
    fi

    info "Installing/Updating Composer..."
    if ! curl -fsSL https://getcomposer.org/composer-stable.phar -o /usr/local/bin/composer; then
        error "Failed to download Composer."
        return 1
    fi
    chmod +x /usr/local/bin/composer
}

install_composer || warn "Composer installation failed; install manually later if needed."

# --- Restart Services ---

restart_apache_safe() {
    if ! is_apache_installed; then return; fi

    info "Restarting Apache..."
    
    # 1. Syntax check first
    if ! apache2ctl -t; then
        error "Apache configuration syntax error! Not restarting to prevent downtime."
        return 1
    fi

    # 2. Robust restart with timeout and kill
    # Try polite restart (20s), then force kill (10s later)
    if ! timeout -k 10 20 systemctl restart apache2; then
        error "Apache failed to restart gracefully. Check logs."
        systemctl status apache2 --no-pager | tail -n 20
        return 1
    fi
    
    info "Apache restarted successfully."
}

restart_apache_safe

# --- PHP Processing Verification ---

verify_php_working() {
    if ! is_apache_installed; then
        return 0
    fi

    # Find a web root to test in
    local web_root="/var/www/html"
    if [[ ! -d "$web_root" ]]; then
        # Try to find DocumentRoot from Apache config
        web_root=$(grep -rh "DocumentRoot" /etc/apache2/sites-enabled/ 2>/dev/null | head -1 | awk '{print $2}' | tr -d '"')
        if [[ -z "$web_root" || ! -d "$web_root" ]]; then
            warn "Cannot determine web root for PHP verification test."
            return 0
        fi
    fi

    # Try to honor the first ServerName/ServerAlias as Host header to avoid vhost mismatch/redirects
    local server_name
    server_name=$(grep -Eh "^\s*Server(Name|Alias)" /etc/apache2/sites-enabled/*.conf 2>/dev/null | awk '{print $2}' | head -1 | tr -d '"')

    # Avoid dotfiles; Apache default security rules often block them.
    local test_file="${web_root}/php-switch-test-$$.php"
    local test_token="PHP_SWITCH_OK_$$"

    info "Running PHP processing verification (web root: ${web_root}${server_name:+, Host: ${server_name}})..."

    # Create test file
    echo "<?php echo '${test_token}'; ?>" > "$test_file"
    chmod 644 "$test_file"

    # Give Apache a moment to fully initialize
    sleep 1

    # Test via curl if available
    if command -v curl >/dev/null 2>&1; then
        local headers_file body_file status_code url response location_header
        local -a host_header=()
        headers_file=$(mktemp)
        body_file=$(mktemp)
        url="http://127.0.0.1/$(basename "$test_file")"

        if [[ -n "$server_name" ]]; then
            host_header=(-H "Host: ${server_name}")
        fi

        status_code=$(curl -s -L --max-time 8 -o "$body_file" -D "$headers_file" -w '%{http_code}' "${host_header[@]}" --insecure "$url" 2>/dev/null || true)
        response=$(head -c 200 "$body_file")
        location_header=$(grep -i '^Location:' "$headers_file" | tail -1 | cut -d' ' -f2- | tr -d '\r')

        rm -f "$test_file" "$headers_file" "$body_file"

        if [[ "$response" == *"$test_token"* ]]; then
            info "PHP verification: PASSED - PHP code is being processed correctly."
            return 0
        elif [[ "$response" == *"<?php"* ]]; then
            error "PHP verification: FAILED - PHP code is NOT being processed!"
            error "Apache is serving raw PHP source code instead of executing it."
            error "Possible causes:"
            error "  1. PHP module not loaded (check: a2query -m | grep php)"
            error "  2. Missing PHP handler in Apache config"
            error "  3. MPM module conflict (mod_php requires mpm_prefork)"
            return 1
        else
            warn "PHP verification: INCONCLUSIVE - HTTP ${status_code}${location_header:+, Location: ${location_header}}."
            warn "Response (first 200 chars): ${response}"
            if [[ -n "$server_name" ]]; then
                warn "Tip: verification uses Host '${server_name}'. If your site forces HTTPS or another hostname, check that apache serves ${url} with that Host header."
            else
                warn "Tip: could be a redirect/virtual host mismatch. Configure ServerName or run curl manually to debug."
            fi
            return 0
        fi
    else
        rm -f "$test_file"
        warn "curl not available, skipping PHP processing verification."
        return 0
    fi
}

# Do not hard-fail the whole switch if the HTTP check fails; surface a warning instead.
verify_php_working || warn "PHP HTTP verification failed; check web root/virtual host setup. See ${LOG_FILE} for details."

# --- Final Report ---

info "--------------------------------------------------"
info "PHP Switch Complete"
info "Current CLI Version: $(php -r 'echo PHP_VERSION;')"
if is_apache_installed; then
    info "Apache Module: $(a2query -m | grep 'php' || echo 'None')"
fi
info "--------------------------------------------------"

exit 0
